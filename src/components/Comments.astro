---
// giscus 댓글 컴포넌트 — GitHub Discussions 기반, 블로그 테마와 자동 연동됨
// 설정값은 https://giscus.app/ko 에서 발급 (data-category, data-category-id 필요)
---

<section id="giscus-comments" class="mx-auto mt-8 w-full max-w-app"></section>

<script is:inline data-astro-rerun>
  // 현재 블로그 테마(data-theme)를 giscus 테마명으로 변환
  function giscusTheme() {
    const theme = document.documentElement.getAttribute("data-theme");
    return theme === "dark" ? "dark" : "light";
  }

  function loadGiscus() {
    const container = document.getElementById("giscus-comments");
    if (!container || container.querySelector("iframe, script")) return;

    const script = document.createElement("script");
    script.src = "https://giscus.app/client.js";
    script.async = true;
    script.crossOrigin = "anonymous";
    script.setAttribute("data-repo", "abyss-s/abyss-s.github.io");
    script.setAttribute("data-repo-id", "R_kgDOTevamA");
    script.setAttribute("data-category", "General");
    script.setAttribute("data-category-id", "DIC_kwDOTevamM4DBs1Q");
    script.setAttribute("data-mapping", "pathname");
    script.setAttribute("data-strict", "0");
    script.setAttribute("data-reactions-enabled", "1");
    script.setAttribute("data-emit-metadata", "0");
    script.setAttribute("data-input-position", "bottom");
    script.setAttribute("data-theme", giscusTheme());
    script.setAttribute("data-lang", "ko");
    container.appendChild(script);
  }

  // 테마 토글 시 giscus iframe에도 테마 변경 메시지 전송
  function syncGiscusTheme() {
    const iframe = document.querySelector("iframe.giscus-frame");
    iframe?.contentWindow?.postMessage(
      { giscus: { setConfig: { theme: giscusTheme() } } },
      "https://giscus.app"
    );
  }

  loadGiscus();
  new MutationObserver(syncGiscusTheme).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"],
  });
</script>
